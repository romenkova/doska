# Self-hosting the full app from prebuilt images (docker-compose.selfhost.yml).
# Copy to .env and fill in. AUTH_LOGIN, AUTH_PASSWORD and AUTH_SECRET are
# required — the server has no defaults and won't start without them.

# Single-user credentials for the web UI and desktop sync.
AUTH_LOGIN=admin
AUTH_PASSWORD=change-me
# Long random string used to sign session tokens, e.g. `openssl rand -hex 32`.
AUTH_SECRET=

# Host port the web UI is published on (defaults to 8080).
WEB_PORT=8080

# Image tag to pull. Defaults to `latest`; pin to a release (e.g. 0.4.0) to
# control upgrades.
# DOCKER_IMAGE_TAG=latest

# --- Database ---
# By default Postgres is bundled (data lives in a Docker volume) and this
# password secures it. Leave DATABASE_URL commented to use it.
POSTGRES_PASSWORD=change-me

# To use your own managed Postgres instead, uncomment this and set it — the
# bundled db is then ignored.
# DATABASE_URL=postgres://user:password@db-host:5432/doska
