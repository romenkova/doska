# Postgres connection string. Set this in prod to point at a real Postgres.
# Leave it UNSET locally: `pnpm dev` runs the DB for you — it starts `db:serve`
# (PGlite persisted to DB_FILE, exposed as a Postgres socket) and connects the
# app to it at postgres://127.0.0.1:5432/postgres. e2e ignores all of this and
# uses an in-memory PGlite per boot.
# DATABASE_URL=postgres://user:pass@host:5432/deck   # prod only
# DB_FILE=pgdata
#
# Inspect the local DB live (while `pnpm dev` is running) over the same socket:
#   DATABASE_URL=postgres://127.0.0.1:5432/postgres pnpm db:studio
# Override the socket port/host with PG_SOCKET_PORT / PG_SOCKET_HOST if 5432 is taken.

# Single-credential auth for the sync API. Copy to `.env` for local dev.
# The whole board is shared; this one login/password pair gates every sync write.
AUTH_LOGIN=admin
AUTH_PASSWORD=change-me
# Random string that signs session cookies. Rotating it invalidates all sessions.
AUTH_SECRET=dev-only-secret-change-me
# Extra origins allowed to call the auth API (CSRF). The server's own origin and
# the desktop app are already trusted; `pnpm dev` adds the Vite dev server. Set
# this only if the web app is served from an origin other than BASE_URL.
# AUTH_TRUSTED_ORIGINS=https://app.example.com

# Desktop auto-update proxy. The release source is fixed internally (no fork
# support yet). GITHUB_TOKEN is needed only while that repo is private; BASE_URL
# is this server's public origin and defaults to the request's origin if unset.
GITHUB_TOKEN=
BASE_URL=
