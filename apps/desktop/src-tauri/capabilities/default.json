{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Default capabilities for the Doska desktop window.",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "core:window:allow-start-dragging",
    "core:webview:allow-set-webview-zoom",
    "window-state:default",
    "updater:default",
    "process:default",
    "opener:default",
    "fs:allow-exists",
    "fs:allow-download-read-recursive",
    "fs:allow-download-write-recursive",
    {
      "identifier": "http:default",
      "allow": [
        { "url": "http://localhost:*/*" },
        { "url": "http://127.0.0.1:*/*" },
        { "url": "http://**" },
        { "url": "https://**" }
      ]
    }
  ]
}
