# Self-hosting the full app from prebuilt images (docker-compose.selfhost.yml).
# Copy to .env and fill in. Only AUTH_PASSWORD and AUTH_SECRET are required.

# Single-user credentials for the web UI and desktop sync.
AUTH_LOGIN=admin
AUTH_PASSWORD=change-me
# Long random string used to sign session tokens, e.g. `openssl rand -hex 32`.
AUTH_SECRET=

# Host port the web UI is published on (defaults to 8080).
WEB_PORT=8080

# Image tag to pull. Defaults to `latest`; pin to a release (e.g. 0.4.0) to
# control upgrades.
# DOCKER_IMAGE_TAG=latest

# --- Database: pick ONE ---

# A) Bundled Postgres (default). Password is internal-only, between the server
#    and db containers. Leave DATABASE_URL unset.
POSTGRES_PASSWORD=deck

# B) Your own managed Postgres. Set this and the bundled db is unused (you can
#    delete the `db` service from the compose file). POSTGRES_PASSWORD is then
#    ignored.
# DATABASE_URL=postgres://user:password@db-host:5432/deck

# Version reported at /api/version (gates desktop auto-updates). The published
# image already bakes this in, so normally leave it unset.
# APP_VERSION=
