# Self-hosting the sync server (docker-compose.sync-selfhost.yml).
# Copy to .env and fill in. Only AUTH_PASSWORD and AUTH_SECRET are required.

# Single-user credentials you'll enter in the desktop app to sync.
AUTH_LOGIN=admin
AUTH_PASSWORD=change-me
# Long random string used to sign session tokens, e.g. `openssl rand -hex 32`.
AUTH_SECRET=

# Host port the sync server is published on. Point the desktop app here.
SERVER_PORT=3000

# Version reported at /api/version (gates desktop auto-updates). Leave unset and
# pass the git tag at deploy instead, so it tracks the code you checked out:
#   APP_VERSION=$(git describe --tags --always | sed 's/^v//') docker compose ... up -d --build
# If unset entirely, the server falls back to apps/server/package.json.
# APP_VERSION=

# --- Database: pick ONE ---

# A) Bundled Postgres (run with `--profile bundled-db`). Password is internal-
#    only, between the server and db containers. Leave DATABASE_URL unset.
POSTGRES_PASSWORD=deck

# B) Your own managed Postgres. Set this and run WITHOUT the bundled-db profile;
#    POSTGRES_PASSWORD above is then ignored.
# DATABASE_URL=postgres://user:password@db-host:5432/deck
