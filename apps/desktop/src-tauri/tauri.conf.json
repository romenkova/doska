{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Doska",
  "version": "0.1.0",
  "identifier": "com.deck.desktop",
  "build": {
    "beforeDevCommand": "pnpm --filter client dev",
    "devUrl": "http://localhost:5173",
    "beforeBuildCommand": "pnpm --filter client build",
    "frontendDist": "../../client/dist"
  },
  "app": {
    "windows": [
      {
        "title": "Doska",
        "width": 1280,
        "height": 800,
        "minWidth": 640,
        "minHeight": 480,
        "titleBarStyle": "Overlay",
        "hiddenTitle": true,
        "dragDropEnabled": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "createUpdaterArtifacts": true,
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  },
  "plugins": {
    "updater": {
      "endpoints": ["https://deck.shpsm.dev/api/desktop/latest.json"],
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IEJCMUM1MjE5MUMwMzdBRkQKUldUOWVnTWNHVkljdSswVEtsVTVFdHhOS3VvWUdiVGYxdU52aGYvdS9tZStEa0llZ2x0MjB5eFcK"
    }
  }
}
