{
  "name": "deck",
  "private": true,
  "version": "0.0.1",
  "type": "module",
  "engines": {
    "node": ">=22",
    "pnpm": ">=11"
  },
  "packageManager": "pnpm@11.8.0",
  "scripts": {
    "dev": "turbo run dev",
    "build": "turbo run build",
    "lint": "turbo run lint",
    "type-check": "turbo run typecheck",
    "format": "prettier --write \"**/*.{ts,tsx,js,json,md}\"",
    "e2e": "turbo run e2e",
    "upd": "pnpm dlx npm-check-updates --workspaces --root -i",
    "prepare": "husky"
  },
  "config": {
    "commitizen": {
      "path": "cz-git"
    }
  },
  "devDependencies": {
    "@commitlint/cli": "^21",
    "@commitlint/config-conventional": "^21",
    "commitizen": "^4",
    "cz-git": "^1",
    "husky": "^9",
    "prettier": "^3.8.4",
    "turbo": "^2"
  }
}
