# External Postgres connection string (required).
DATABASE_URL=postgres://user:password@db-host:5432/deck

# Single-user credentials for the sync API.
AUTH_LOGIN=admin
AUTH_PASSWORD=change-me
# Long random string used to sign session tokens, e.g. `openssl rand -hex 32`.
AUTH_SECRET=

# Host port the web UI is published on (defaults to 8080).
WEB_PORT=8080

# Version reported at /api/version (gates desktop auto-updates). Leave this unset
# and pass the git tag at deploy instead, so it tracks the code you checked out:
#   APP_VERSION=$(git describe --tags --always | sed 's/^v//') docker compose ... up -d --build
# If unset entirely, the server falls back to apps/server/package.json.
# APP_VERSION=
